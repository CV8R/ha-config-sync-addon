---
extends: default

rules:
  line-length:
    max: 120
    level: warning

  indentation:
    spaces: 2
    indent-sequences: true

  comments:
    min-spaces-from-content: 2

  document-start:
    present: false

  truthy:
    allowed-values: ["true", "false", "yes", "no", "on", "off"]
    check-keys: false

  quoted-strings:
    quote-type: any
    required: false

ignore: |
  .git/
  .venv/
  venv/
  __pycache__/
